# ==============================================================================
# MedSecure Platform - Environment Variables
# ==============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# ==============================================================================

# ------------------------------------------------------------------------------
# Application
# ------------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# ------------------------------------------------------------------------------
# PostgreSQL Database
# ------------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=medsecure
DB_PASSWORD=
DB_NAME=medsecure_db

# ------------------------------------------------------------------------------
# Test Database (used by test suite and backup verification)
# ------------------------------------------------------------------------------
TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_USER=medsecure
TEST_DB_PASSWORD=
TEST_DB_NAME=medsecure_test_db

# ------------------------------------------------------------------------------
# Authentication
# ------------------------------------------------------------------------------
# Secret key for signing JSON Web Tokens (use a strong random string)
JWT_SECRET=

# ------------------------------------------------------------------------------
# Encryption
# ------------------------------------------------------------------------------
# AES-256-GCM key for encrypting PHI (64-character hex string = 32 bytes)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
# Levels: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=info

# ------------------------------------------------------------------------------
# Backup Verification
# ------------------------------------------------------------------------------
# Set to 'false' to disable the backup verification scheduler
BACKUP_VERIFICATION_ENABLED=true
# Cron expression for backup verification schedule (default: 3 AM daily)
BACKUP_VERIFICATION_SCHEDULE=0 3 * * *
