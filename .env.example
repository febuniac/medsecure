# =============================================================================
# MedSecure Platform - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_USER=medsecure
DB_PASSWORD=
DB_NAME=medsecure_db

# -----------------------------------------------------------------------------
# Test Database (used by backup verification and test suites)
# -----------------------------------------------------------------------------
TEST_DB_HOST=localhost
TEST_DB_PORT=5432
TEST_DB_USER=medsecure
TEST_DB_PASSWORD=
TEST_DB_NAME=medsecure_test_db

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# Secret key for signing JSON Web Tokens (min 256-bit recommended)
JWT_SECRET=

# -----------------------------------------------------------------------------
# Encryption
# -----------------------------------------------------------------------------
# AES-256-GCM key for PHI encryption (64 hex characters = 256 bits)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Levels: error, warn, info, http, verbose, debug, silly
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# Comma-separated list of allowed origins (default: https://portal.medsecure.com)
CORS_ALLOWED_ORIGINS=https://portal.medsecure.com

# -----------------------------------------------------------------------------
# S3 / Object Storage (for medical image attachments)
# -----------------------------------------------------------------------------
# AWS region for the S3 bucket
AWS_REGION=us-east-1
# S3 bucket name for storing medical images
S3_BUCKET_NAME=medsecure-medical-images
# Optional: custom S3 endpoint (for MinIO, LocalStack, etc.)
# S3_ENDPOINT=http://localhost:9000
# Optional: force path-style URLs (required for MinIO / LocalStack)
# S3_FORCE_PATH_STYLE=true

# -----------------------------------------------------------------------------
# Backup Verification
# -----------------------------------------------------------------------------
# Set to 'false' to disable automatic backup verification
BACKUP_VERIFICATION_ENABLED=true
# Cron schedule for backup verification (default: daily at 3 AM)
BACKUP_VERIFICATION_SCHEDULE=0 3 * * *
